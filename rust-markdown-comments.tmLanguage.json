{
	"scopeName": "source.rust.markdown",
	"injectionSelector": "L:source.rust -comment -string",
	"patterns": [
		{
			"include": "#markdown-in-comments"
		}
	],
	"repository": {
		"markdown-in-comments": {
			"patterns": [
				{
					"match": "(\\*\\*)(.+?)(\\*\\*)",
					"captures": {
						"1": { "name": "punctuation.definition.bold.markdown" },
						"2": { "name": "markup.bold.markdown" },
						"3": { "name": "punctuation.definition.bold.markdown" }
					}
				},
				{
					"match": "(\\*)(.+?)(\\*)",
					"captures": {
						"1": { "name": "punctuation.definition.italic.markdown" },
						"2": { "name": "markup.italic.markdown" },
						"3": { "name": "punctuation.definition.italic.markdown" }
					}
				},
				{
					"match": "(`)(.+?)(`)",
					"captures": {
						"1": { "name": "punctuation.definition.raw.markdown" },
						"2": { "name": "markup.inline.raw.markdown" },
						"3": { "name": "punctuation.definition.raw.markdown" }
					}
				},
				{
					"match": "(\\[)(.+?)(\\])\\((.+?)\\)",
					"captures": {
						"1": { "name": "punctuation.definition.link.begin.markdown" },
						"2": { "name": "string.other.link.title.markdown" },
						"3": { "name": "punctuation.definition.link.end.markdown" },
						"4": { "name": "markup.underline.link.markdown" }
					}
				},
				{
					"match": "^(#{1,6})\\s+(.+)$",
					"captures": {
						"1": { "name": "punctuation.definition.heading.markdown" },
						"2": { "name": "markup.heading.markdown entity.name.section.markdown" }
					}
				},
				{
					"match": "^(\\s*)[-*+]\\s+",
					"captures": {
						"1": { "name": "punctuation.whitespace.leading.markdown" },
						"2": { "name": "punctuation.definition.list.markdown" }
					}
				},
				{
					"match": "^(\\s*)>\\s*",
					"captures": {
						"1": { "name": "punctuation.whitespace.leading.markdown" },
						"2": { "name": "punctuation.definition.blockquote.markdown" }
					}
				}
			]
		}
	}
}
